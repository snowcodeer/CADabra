# Copy this file to .env and fill in real values. .env is gitignored.

# Anthropic API key used by scripts/vision_tune_recon.py (cohesion grader)
# and backend/pipeline/llm_client.py (CadQuery code generation).
ANTHROPIC_API_KEY=sk-ant-...

# OpenAI API key used by scripts/synthesize_clean_views.py to clean small
# cosmetic gaps in the rendered orthographic geometry views with gpt-image-2.
# Optional - only needed if you want the synthetic clean PNGs alongside the
# raw recon-only ones.
OPENAI_API_KEY=sk-proj-...
